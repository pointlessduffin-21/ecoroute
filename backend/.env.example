# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecoroute
# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=ecoroute
MQTT_PASSWORD=secret
# Redis
REDIS_URL=redis://localhost:6379
# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Server
PORT=3000
NODE_ENV=development
# JWT (fallback if not using Supabase Auth)
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
# Device API Key (for ESP32 HTTP telemetry ingestion)
DEVICE_API_KEY=your-device-api-key
