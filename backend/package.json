{
  "name": "ecoroute-backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:node": "node --import tsx/esm --watch src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "start:bun": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "mcp": "bun run src/mcp/ecoroute-mcp-server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.95.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.11.9",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.15.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  }
}
